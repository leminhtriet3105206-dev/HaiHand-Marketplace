<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản lý Báo cáo - HaiHand Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-slate-100 flex min-h-screen font-sans">
    
    <%- include('partials/sidebar', {active: 'reports'}) %>

    <div class="flex-1 p-10 h-screen overflow-y-auto ml-64">
        
        <div class="flex justify-between items-center mb-8">
            <h2 class="text-3xl font-black tracking-tight text-slate-800">🚩 Quản lý Báo cáo Vi phạm</h2>
            <div class="bg-red-100 text-red-600 px-4 py-2 rounded-full text-xs font-black uppercase shadow-sm">
                Tổng cộng: <%= reports.length %> yêu cầu
            </div>
        </div>

        <% if(reports.length === 0) { %>
            <div class="bg-white rounded-2xl p-20 text-center shadow-sm border border-slate-200">
                <div class="text-6xl mb-4 opacity-50">🍃</div>
                <p class="font-bold text-slate-400">Hiện tại hệ thống sạch bóng vi phạm!</p>
            </div>
        <% } else { %>
            <div class="grid gap-6">
                <% reports.forEach(report => { %>
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 hover:border-red-300 transition-all flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                    <div class="flex gap-5 items-start">
                        <div class="bg-red-50 text-red-500 p-4 rounded-2xl text-2xl shadow-inner">
                            ⚠️
                        </div>
                        <div>
                            <div class="flex items-center gap-3 mb-1">
                                <h4 class="font-black text-slate-800 text-lg"><%= report.reason %></h4>
                                <span class="bg-slate-100 text-slate-500 text-[10px] px-2 py-0.5 rounded font-bold uppercase">
                                    <%= report.status %>
                                </span>
                            </div>
                            <p class="text-xs text-slate-500 mb-3">
                                Người gửi: <span class="font-bold text-slate-700"><%= report.reporter?.name || 'Ẩn danh' %></span> 
                                <span class="mx-2">|</span> 
                                Ngày: <span class="font-mono"><%= new Date(report.createdAt).toLocaleString('vi-VN') %></span>
                            </p>
                            
                            <% if(report.post) { %>
                                <a href="http://localhost:3000/post/<%= report.post._id %>" target="_blank" 
                                   class="inline-flex items-center gap-2 bg-blue-50 text-blue-600 px-3 py-1.5 rounded-lg text-[11px] font-black hover:bg-blue-600 hover:text-white transition-all border border-blue-100">
                                    🔗 XEM TIN ĐĂNG: <%= report.post.title %>
                                </a>
                            <% } else { %>
                                <span class="text-[11px] text-red-400 font-bold italic">Tin đăng này đã bị xóa trước đó.</span>
                            <% } %>
                        </div>
                    </div>
                    
                    <div class="flex flex-row md:flex-col gap-2 w-full md:w-auto">
                        <form action="/admin/reports/ignore/<%= report._id %>" method="POST" class="flex-1 md:w-full">
                            <button class="w-full px-5 py-2.5 bg-slate-100 text-slate-600 rounded-xl text-xs font-black hover:bg-slate-200 transition-all">
                                BỎ QUA
                            </button>
                        </form>
                        
                        <% if(report.post) { %>
                        <form action="/admin/posts/delete/<%= report.post._id %>" method="POST" onsubmit="return confirm('❗ Ní có chắc muốn XÓA VĨNH VIỄN bài viết vi phạm này không?')" class="flex-1 md:w-full">
                            <button class="w-full px-5 py-2.5 bg-red-600 text-white rounded-xl text-xs font-black hover:bg-red-700 shadow-lg shadow-red-200 transition-all">
                                XÓA VI PHẠM
                            </button>
                        </form>
                        <% } %>
                    </div>
                </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</body>
</html>