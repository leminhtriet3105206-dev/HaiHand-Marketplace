<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Tổng quan - HaiHand Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-slate-100 flex min-h-screen">
    
    <%- include('partials/sidebar', {active: 'dashboard'}) %>

    <div class="flex-1 p-10 h-screen overflow-y-auto ml-64">
        <h2 class="text-3xl font-black text-slate-800 mb-8 tracking-tight">📊 Tổng quan hệ thống</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
            <div class="bg-white p-6 rounded-3xl shadow-sm border border-slate-200 border-l-4 border-l-blue-500 hover:shadow-md transition">
                <h3 class="text-slate-500 font-bold text-xs uppercase tracking-wider">Tổng tin đăng</h3>
                <p class="text-4xl font-black text-slate-800 mt-2"><%= stats.postCount %></p>
            </div>
            <div class="bg-white p-6 rounded-3xl shadow-sm border border-slate-200 border-l-4 border-l-green-500 hover:shadow-md transition">
                <h3 class="text-slate-500 font-bold text-xs uppercase tracking-wider">Tổng người dùng</h3>
                <p class="text-4xl font-black text-slate-800 mt-2"><%= stats.userCount %></p>
            </div>
            <div class="bg-white p-6 rounded-3xl shadow-sm border border-slate-200 border-l-4 border-l-yellow-500 hover:shadow-md transition">
                <h3 class="text-slate-500 font-bold text-xs uppercase tracking-wider">Tin chờ duyệt</h3>
                <p class="text-4xl font-black text-slate-800 mt-2"><%= stats.pendingCount %></p>
            </div>
            <div class="bg-white p-6 rounded-3xl shadow-sm border border-slate-200 border-l-4 border-l-orange-500 bg-orange-50/30 hover:shadow-md transition">
                <h3 class="text-orange-600 font-bold text-xs uppercase tracking-wider">Doanh thu sàn (5%)</h3>
                <p class="text-3xl font-black text-orange-700 mt-2"><%= stats.revenue.toLocaleString('vi-VN') %> đ</p>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <div class="lg:col-span-2 space-y-8">
                <div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
                    <div class="p-6 border-b border-slate-50 bg-slate-50/50 flex justify-between items-center">
                        <h3 class="text-lg font-bold text-slate-800 flex items-center">
                            <span class="mr-2">💰</span> Giao dịch thu phí gần nhất
                        </h3>
                        <a href="/admin/revenue" class="text-blue-600 text-sm font-bold hover:underline">Xem tất cả →</a>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead>
                                <tr class="text-slate-400 text-[10px] uppercase tracking-widest border-b border-slate-50 bg-slate-50/30">
                                    <th class="px-6 py-4">Thời gian</th>
                                    <th class="px-6 py-4">Mã đơn</th>
                                    <th class="px-6 py-4">Khách hàng</th>
                                    <th class="px-6 py-4 text-right">Phí thu (5%)</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-50">
                                <% if (recentRevenues && recentRevenues.length === 0) { %>
                                    <tr>
                                        <td colspan="4" class="px-6 py-10 text-center text-slate-400 font-medium italic">Chưa có giao dịch chiết khấu nào.</td>
                                    </tr>
                                <% } else if (recentRevenues) { %>
                                    <% recentRevenues.forEach(rev => { %>
                                        <tr class="hover:bg-slate-50/80 transition">
                                            <td class="px-6 py-4 text-xs text-slate-500">
                                                <%= rev.createdAt.toLocaleString('vi-VN', {hour: '2-digit', minute:'2-digit', day:'2-digit', month:'2-digit'}) %>
                                            </td>
                                            <td class="px-6 py-4">
                                                <span class="bg-slate-100 text-slate-700 px-2 py-1 rounded-lg text-[10px] font-black border border-slate-200">
                                                    #<%= rev.orderId?._id.toString().slice(-6).toUpperCase() %>
                                                </span>
                                            </td>
                                            <td class="px-6 py-4 font-bold text-slate-700 text-sm">
                                                <%= rev.orderId?.buyer?.name || 'N/A' %>
                                            </td>
                                            <td class="px-6 py-4 text-right">
                                                <span class="text-emerald-600 font-black text-sm">+<%= rev.commissionAmount.toLocaleString('vi-VN') %> đ</span>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="bg-white rounded-3xl shadow-sm border border-slate-200 p-6">
                    <h3 class="text-lg font-bold text-slate-800 mb-6 flex justify-between items-center">
                        <span class="flex items-center"><span class="mr-2">⏳</span> Bài viết chờ duyệt</span>
                        <a href="/posts" class="text-sm text-blue-500 font-bold hover:underline italic">Tất cả bài viết</a>
                    </h3>
                    
                    <% if(recentPending.length === 0) { %>
                        <div class="text-slate-500 text-center py-8 bg-slate-50 rounded-2xl border border-dashed border-slate-200 font-medium">
                            🌿 Không có bài viết nào đang chờ duyệt. Tuyệt vời!
                        </div>
                    <% } else { %>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <% recentPending.forEach(post => { %>
                                <div class="flex items-center justify-between p-4 bg-white rounded-2xl border border-slate-100 shadow-sm hover:border-yellow-300 transition group">
                                    <div class="flex items-center space-x-3 overflow-hidden">
                                        <div class="bg-yellow-100 p-2 rounded-xl group-hover:scale-110 transition">📦</div>
                                        <div class="overflow-hidden">
                                            <p class="font-bold text-slate-800 text-sm truncate"><%= post.title %></p>
                                            <p class="text-[10px] text-slate-500">Người đăng: <%= post.author ? post.author.name : 'Vô danh' %></p>
                                        </div>
                                    </div>
                                    <a href="/posts/approve/<%= post._id %>" onclick="return confirm('Duyệt bài này?')" class="text-[10px] font-black text-white bg-green-500 px-4 py-2 rounded-xl hover:bg-green-600 shadow-sm shadow-green-100">DUYỆT</a>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
            </div>

            <div class="bg-white rounded-3xl shadow-sm border border-slate-200 p-6 h-fit">
                <h3 class="text-lg font-bold text-slate-800 mb-6 flex items-center">
                    <span class="mr-2">👋</span> Người dùng mới
                </h3>
                
                <% if(recentUsers.length === 0) { %>
                    <p class="text-slate-500 text-center py-4">Chưa có người dùng mới.</p>
                <% } else { %>
                    <div class="space-y-4">
                        <% recentUsers.forEach(user => { %>
                            <div class="flex items-center space-x-3 p-3 hover:bg-slate-50 rounded-2xl transition border border-transparent hover:border-slate-100">
                                <div class="bg-blue-100 text-blue-600 font-black w-10 h-10 rounded-2xl flex items-center justify-center text-sm">
                                    <%= user.name.charAt(0).toUpperCase() %>
                                </div>
                                <div class="overflow-hidden">
                                    <p class="font-bold text-slate-800 text-sm truncate"><%= user.name %></p>
                                    <p class="text-[10px] text-slate-400 italic">Gia nhập: <%= new Date(user.createdAt).toLocaleDateString('vi-VN') %></p>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
                <a href="/users" class="block w-full text-center mt-6 text-slate-400 text-xs font-bold hover:text-slate-600">Quản lý toàn bộ người dùng →</a>
            </div>
        </div>
    </div>
</body>
</html>