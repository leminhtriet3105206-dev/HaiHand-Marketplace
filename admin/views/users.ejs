<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>AdminPro - Quản lý người dùng</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 flex min-h-screen font-sans">
    
    <%- include('partials/sidebar') %>

    <div class="flex-1 p-10 h-screen overflow-y-auto">
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-3xl font-bold text-slate-800">👥 Quản lý người dùng</h2>
            
            <div class="relative w-80">
                <input type="text" id="userSearch" onkeyup="filterUsers()" placeholder="Tìm tên, email, số điện thoại..." 
                       class="w-full px-4 py-2 pl-10 border border-slate-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                <span class="absolute left-3 top-2.5 text-slate-400">🔍</span>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
            <table class="w-full text-left border-collapse" id="userTable">
                <thead class="bg-slate-50 border-b border-slate-200">
                    <tr>
                        <th class="p-4 font-bold text-slate-600 uppercase text-xs">Họ tên</th>
                        <th class="p-4 font-bold text-slate-600 uppercase text-xs">Liên hệ</th>
                        <th class="p-4 font-bold text-slate-600 uppercase text-xs">Vai trò</th>
                        <th class="p-4 font-bold text-slate-600 uppercase text-xs">Ngày tham gia</th>
                        <th class="p-4 font-bold text-slate-600 uppercase text-xs text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(user => { %>
                    <tr class="border-b border-slate-100 hover:bg-slate-50 transition user-row">
                        <td class="p-4 font-bold text-slate-700"><%= user.name %></td>
                        <td class="p-4 text-sm text-slate-600">
                            📧 <%= user.email %><br>
                            📞 <%= user.phone || 'Chưa cập nhật' %>
                        </td>
                        <td class="p-4">
                            <% if(user.role === 'Admin') { %>
                                <span class="bg-purple-100 text-purple-700 px-2 py-1 rounded text-xs font-bold">Admin</span>
                            <% } else { %>
                                <span class="bg-gray-100 text-gray-700 px-2 py-1 rounded text-xs font-bold">Khách hàng</span>
                            <% } %>
                        </td>
                        <td class="p-4 text-sm text-slate-500">
                            <%= new Date(user.createdAt).toLocaleDateString('vi-VN') %>
                        </td>
                        <td class="p-4 text-center space-x-2">
                            <a href="/users/edit/<%= user._id %>" class="inline-block text-blue-500 hover:text-blue-700 font-bold bg-blue-50 px-3 py-1 rounded hover:bg-blue-100 transition">
                                ✏️ Sửa
                            </a>
                            <a href="/users/delete/<%= user._id %>" onclick="return confirm('Xóa người dùng này?')" class="inline-block text-red-500 hover:text-red-700 font-bold bg-red-50 px-3 py-1 rounded hover:bg-red-100 transition">
                                🗑 Xóa
                            </a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            
            <div id="noResults" class="hidden text-center py-10">
                <p class="text-slate-500 text-lg">Không tìm thấy người dùng nào phù hợp!</p>
            </div>
        </div>
    </div>

    <script>
        function filterUsers() {
            const input = document.getElementById("userSearch").value.toLowerCase();
            const rows = document.querySelectorAll(".user-row");
            let hasData = false;
            
            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                if (text.includes(input)) {
                    row.style.display = "";
                    hasData = true;
                } else {
                    row.style.display = "none";
                }
            });
            if (hasData) {
                document.getElementById("noResults").classList.add("hidden");
                document.getElementById("userTable").classList.remove("hidden");
            } else {
                document.getElementById("noResults").classList.remove("hidden");
                document.getElementById("userTable").classList.add("hidden");
            }
        }
    </script>
</body>
</html>