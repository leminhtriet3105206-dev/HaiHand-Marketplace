<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Chi tiết đơn hàng #<%= order._id.toString().slice(-6).toUpperCase() %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 flex min-h-screen">
    <%- include('partials/sidebar', {active: 'orders'}) %>

    <div class="flex-1 p-10 ml-64">
        <div class="mb-6">
            <a href="/admin/orders" class="text-slate-500 hover:text-slate-800 font-bold text-sm">← Quay lại danh sách</a>
        </div>

        <div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-slate-200">
            <div class="bg-slate-900 p-8 text-white flex justify-between items-center">
                <div>
                    <h2 class="text-2xl font-black">Đơn hàng #<%= order._id.toString().slice(-6).toUpperCase() %></h2>
                    <p class="text-slate-400 text-sm">Ngày đặt: <%= new Date(order.createdAt).toLocaleString('vi-VN') %></p>
                </div>
                <div class="text-right">
                    <span class="px-4 py-2 rounded-full text-xs font-black uppercase bg-yellow-400 text-slate-900">
                        <%= order.status %>
                    </span>
                </div>
            </div>

            <div class="p-8 grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="space-y-6">
                    <div>
                        <h3 class="text-slate-400 uppercase text-[10px] font-black tracking-widest mb-3">Người mua</h3>
                        <div class="flex items-center gap-3">
                            <img src="<%= order.buyer?.avatar || 'https://via.placeholder.com/40' %>" class="w-10 h-10 rounded-full border">
                            <div>
                                <p class="font-bold text-slate-800"><%= order.buyer?.name %></p>
                                <p class="text-xs text-slate-500"><%= order.buyer?.email %></p>
                            </div>
                        </div>
                    </div>
                    <div class="pt-4 border-top">
                        <h3 class="text-slate-400 uppercase text-[10px] font-black tracking-widest mb-3">Người bán</h3>
                        <div class="flex items-center gap-3">
                            <img src="<%= order.seller?.avatar || 'https://via.placeholder.com/40' %>" class="w-10 h-10 rounded-full border">
                            <p class="font-bold text-slate-800"><%= order.seller?.name %></p>
                        </div>
                    </div>
                </div>

                <div class="md:col-span-2 bg-slate-50 rounded-2xl p-6 border border-slate-100">
                    <h3 class="text-slate-800 font-black mb-4 italic">Sản phẩm trong đơn</h3>
                    <div class="space-y-4">
                        <% order.items.forEach(item => { %>
                        <div class="flex justify-between items-center bg-white p-4 rounded-xl shadow-sm">
                            <div class="flex items-center gap-4">
                                <div class="w-16 h-16 bg-slate-200 rounded-lg overflow-hidden">
                                    <img src="<%= item.product?.images?.[0] || 'https://via.placeholder.com/100' %>" class="w-full h-full object-cover">
                                </div>
                                <div>
                                    <p class="font-bold text-slate-800"><%= item.product?.title %></p>
                                    <p class="text-xs text-slate-400">Số lượng: x<%= item.quantity %></p>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="font-black text-slate-800"><%= (item.price * item.quantity).toLocaleString('vi-VN') %> đ</p>
                            </div>
                        </div>
                        <% }) %>
                    </div>

                    <div class="mt-6 pt-6 border-t-2 border-dashed border-slate-200 flex justify-between items-center">
                        <span class="text-slate-500 font-bold">TỔNG THANH TOÁN:</span>
                        <span class="text-2xl font-black text-red-600"><%= order.totalAmount.toLocaleString('vi-VN') %> đ</span>
                    </div>
                </div>
            </div>
            
            <div class="bg-slate-50 p-6 border-t border-slate-200 flex justify-between text-sm">
                <p class="text-slate-500">Hình thức: <span class="font-bold text-slate-800"><%= order.paymentMethod || 'VNPay' %></span></p>
                <p class="text-slate-500">Mã giao dịch: <span class="font-mono text-blue-600"><%= order.paymentId || 'N/A' %></span></p>
            </div>
        </div>
    </div>
</body>
</html>