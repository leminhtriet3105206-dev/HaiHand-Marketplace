<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Chỉnh sửa người dùng</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 flex min-h-screen font-sans">
    
    <%- include('partials/sidebar') %>

    <div class="flex-1 p-10 h-screen overflow-y-auto">
        <div class="max-w-2xl mx-auto bg-white rounded-xl shadow-sm border border-slate-200 p-8">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-2xl font-bold text-slate-800">✏️ Chỉnh sửa thông tin</h2>
                <a href="/users" class="text-slate-500 hover:text-slate-800 font-medium">← Quay lại</a>
            </div>

            <form action="/users/edit/<%= user._id %>" method="POST" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Họ tên</label>
                    <input type="text" name="name" value="<%= user.name %>" required
                           class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Email</label>
                    <input type="email" name="email" value="<%= user.email %>" required
                           class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Số điện thoại</label>
                    <input type="text" name="phone" value="<%= user.phone %>" 
                           class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Vai trò</label>
                    <select name="role" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                        <option value="Khách hàng" <%= user.role === 'Khách hàng' ? 'selected' : '' %>>Khách hàng</option>
                        <option value="Admin" <%= user.role === 'Admin' ? 'selected' : '' %>>Admin</option>
                    </select>
                </div>

                <div class="pt-4">
                    <button type="submit" class="w-full bg-blue-600 text-white font-bold py-3 rounded-lg hover:bg-blue-700 transition">
                        Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>