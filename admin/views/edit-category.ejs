<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Sửa danh mục - Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 flex min-h-screen font-sans">
    
    <%- include('partials/sidebar') %>

    <div class="flex-1 p-10 h-screen overflow-y-auto">
        <div class="mb-6 flex items-center space-x-4">
            <a href="/categories" class="text-slate-500 hover:text-slate-800 font-bold text-xl transition">← Quay lại</a>
            <h2 class="text-3xl font-bold text-slate-800">✏️ Sửa danh mục</h2>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden max-w-2xl">
            <div class="bg-blue-500 text-white font-bold p-4">
                Cập nhật thông tin danh mục
            </div>
            <div class="p-6">
                <form action="/categories/edit/<%= category._id %>" method="POST" enctype="multipart/form-data">
                    
                    <div class="mb-4">
                        <label class="block font-bold text-slate-700 mb-2">Tên danh mục</label>
                        <input type="text" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" name="name" value="<%= category.name %>" required />
                    </div>
                    
                    <div class="mb-4">
                        <label class="block font-bold text-slate-700 mb-2">Ghi chú (Mô tả)</label>
                        <textarea class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" name="description" rows="3"><%= category.description || '' %></textarea>
                    </div>

                    <div class="mb-6 border-t border-slate-200 pt-4">
                        <label class="block font-bold text-slate-700 mb-2">Icon hình ảnh hiện tại</label>
                        <div class="mb-3">
                            <% 
                                let imgSrc = 'https://upload.wikimedia.org/wikipedia/commons/1/14/No_Image_Available.jpg';
                                if (category.image) {
                                    imgSrc = category.image.startsWith('http') ? category.image : '/uploads/' + category.image;
                                }
                            %>
                            <img src="<%= imgSrc %>" 
                                 onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/1/14/No_Image_Available.jpg'" 
                                 class="w-20 h-20 object-cover rounded-lg shadow-sm border border-slate-200" 
                                 alt="Icon danh mục" />
                        </div>
                        <label class="block font-bold text-slate-700 mb-2">Tải icon mới <span class="text-sm text-slate-400 font-normal">(Bỏ trống nếu muốn giữ nguyên ảnh cũ)</span></label>
                        <input type="file" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" name="image" accept="image/*" />
                    </div>

                    <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-lg transition">
                        💾 Lưu thay đổi
                    </button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>