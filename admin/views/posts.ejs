<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HaiHand Admin - Quản lý tin đăng</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f4f7f6; font-family: 'Inter', sans-serif; }
        .card-table { border: none; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.04); background: white; }
        .product-img { width: 55px; height: 55px; object-fit: cover; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        .status-badge { font-size: 11px; padding: 6px 12px; border-radius: 50px; font-weight: 600; text-transform: uppercase; }
        .btn-action { border-radius: 8px; font-size: 13px; font-weight: 600; padding: 6px 15px; }
        .table thead th { background-color: #f8f9fa; border-top: none; color: #6c757d; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; }
    </style>
</head>
<body class="flex min-h-screen">

    <%- include('partials/sidebar') %>

    <div class="flex-1 p-10 h-screen overflow-y-auto w-full">
        <div class="container-fluid px-0">
            <div class="row align-items-center mb-4">
                <div class="col">
                    <h2 class="fw-bold m-0 text-dark">Kiểm duyệt tin đăng</h2>
                    <p class="text-muted small">Nơi đảm bảo nội dung sạch cho cộng đồng HaiHand</p>
                </div>
                <div class="col-auto">
                    <div class="input-group shadow-sm" style="width: 350px;">
                        <span class="input-group-text bg-white border-end-0 text-muted">🔍</span>
                        <input type="text" id="adminSearch" class="form-control border-start-0 py-2 ps-0" placeholder="Tìm sản phẩm, người bán..." onkeyup="filterPosts()">
                    </div>
                </div>
            </div>

            <div class="card card-table overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" id="postTable">
                        <thead>
                            <tr>
                                <th class="ps-4 py-3">Sản phẩm</th>
                                <th>Người bán</th>
                                <th>Giá niêm yết</th>
                                <th>Danh mục</th>
                                <th>Trạng thái</th>
                                <th class="text-center">Quản lý</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% posts.forEach(post => { %>
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center py-2">
                                        <% 
                                            
                                            let imgSrc = 'https://upload.wikimedia.org/wikipedia/commons/1/14/No_Image_Available.jpg';
                                            if (post.images && post.images.length > 0) {
                                                imgSrc = post.images[0].startsWith('http') ? post.images[0] : '/' + post.images[0].replace(/\\/g, '/');
                                            } else if (post.image) {
                                                imgSrc = post.image.startsWith('http') ? post.image : '/uploads/' + post.image;
                                            }
                                        %>
                                        <img src="<%= imgSrc %>" class="product-img me-3" onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/1/14/No_Image_Available.jpg'">
                                        <div>
                                            <div class="fw-bold text-dark"><%= post.title %></div>
                                            <small class="text-muted"><i class="me-1">📍</i><%= post.location %></small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="small fw-bold"><%= post.author ? post.author.name : 'Vô danh' %></div>
                                    </div>
                                    <small class="text-muted"><%= post.author ? post.author.email : '' %></small>
                                </td>
                                <td>
                                    <span class="text-danger fw-bold">
                                        <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(post.price) %>
                                    </span>
                                </td>
                                <td><span class="badge bg-light text-secondary border px-2"><%= post.category %></span></td>
                                <td>
                                    <% if(post.status === 'PENDING') { %>
                                        <span class="badge bg-warning-subtle text-warning status-badge">⌛ Đang chờ</span>
                                    <% } else { %>
                                        <span class="badge bg-success-subtle text-success status-badge">✅ Đã duyệt</span>
                                    <% } %>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <% if(post.status === 'PENDING') { %>
                                            <button class="btn btn-sm btn-success btn-action" onclick="approvePost('<%= post._id %>')">Duyệt bài</button>
                                        <% } %>
                                        <button class="btn btn-sm btn-outline-danger btn-action" onclick="deletePost('<%= post._id %>')">Gỡ bỏ</button>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <div id="noResults" class="text-center py-5 d-none">
                    <div class="display-1 text-muted opacity-25 mb-3">📦</div>
                    <h5 class="text-muted">Không tìm thấy dữ liệu nào!</h5>
                </div>
            </div>
        </div>
    </div>

    <script>
        function filterPosts() {
            const input = document.getElementById("adminSearch").value.toLowerCase();
            const rows = document.querySelectorAll("#postTable tbody tr");
            let hasData = false;
            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                if (text.includes(input)) {
                    row.style.display = "";
                    hasData = true;
                } else {
                    row.style.display = "none";
                }
            });
            document.getElementById("noResults").classList.toggle("d-none", hasData);
        }

        
        async function deletePost(id) {
            if(!confirm("❗ Bẩm lão đại, ngài có chắc chắn muốn XÓA vĩnh viễn tin này chứ? Hành động này không thể hoàn tác!")) {
                return;
            }
            
            try {
                const response = await fetch(`/api/posts/${id}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    alert("⚔️ Bẩm, đã trảm bài đăng thành công!");
                    window.location.reload(); 
                } else {
                    alert("Lỗi: Kẻ địch quá mạnh, không thể gỡ bỏ! (Hãy đảm bảo Server đã có API DELETE /api/posts/:id)");
                }
            } catch (error) {
                console.error("Lỗi Server:", error);
                alert("Đã xảy ra sự cố sập cầu dao khi kết nối với server!");
            }
        }

        
        function approvePost(id) {
            if (confirm("Phê duyệt bài đăng này để hiển thị công khai trên HaiHand?")) {
                window.location.href = "/posts/approve/" + id;
            }
        }
    </script>
</body>
</html>